# Local dev defaults to a SQLite file so the backend runs with zero setup.
# Deployed: Railway injects a postgresql:// URL — app/db/session.py rewrites it
# to the postgresql+psycopg dialect automatically.
DATABASE_URL=sqlite:///./music_empire.db

# MUST be replaced on any public instance. With ENVIRONMENT=production the app
# refuses to start while this is still the sample value, because anyone reading
# the repo could otherwise forge a login token for any account.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# 14 days — a short-lived token expires mid-play and every action then fails
# with a 401. Shorten this for a real deployment (and add refresh tokens).
JWT_EXPIRE_MINUTES=20160

# "development" or "production". production enables the JWT secret check above.
ENVIRONMENT=development

# Comma-separated invite codes. Empty = anyone can register (fine locally).
# Set this on the deployed instance to keep signups to people you've invited.
# INVITE_CODES=music-empire-2026,friends
INVITE_CODES=

# Origins allowed to call the API. On deploy this must be the Vercel URL, or
# the browser blocks every request and the app silently does nothing.
CORS_ORIGINS=http://localhost:5173
